  },
  "devDependencies": {
    "@eslint/js": "9.36.0",
    "@playwright/test": "1.55.1",
    "@types/node": "24.5.2",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.6.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.2",
    "typescript-eslint": "8.44.1"
  },
  "engines": {
    "node": ">=20.0"
  },
  "pnpm": {
    "overrides": {
