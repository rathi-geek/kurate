# Mobile Component Patterns

## Screen structure — keep screens thin

```tsx
// ✅ correct: screen orchestrates, components render
export default function MyScreen() {
  const { data, isLoading, error } = useMyData();   // logic in hook
  if (isLoading) return <LoadingSkeleton />;
  if (error) return <ErrorState message={error.message} />;
  return <MyFeatureList items={data} />;
}

// ❌ wrong: business logic inline in screen
export default function MyScreen() {
  const [data, setData] = useState([]);
  useEffect(() => { fetch('/api/...').then(...) }, []);
  // ... 200 lines of mixed logic and UI
}
```

## Loading state — use Skeleton

```tsx
import { Skeleton } from '@/components/ui/skeleton';

function LoadingSkeleton() {
  return (
    <VStack className="p-4 gap-3">
      <Skeleton className="h-6 w-3/4 rounded-md" />
      <Skeleton className="h-4 w-full rounded-md" />
      <Skeleton className="h-4 w-5/6 rounded-md" />
    </VStack>
  );
}
```

## Empty state — centered prompt

```tsx
function EmptyState({ message, onCta }: { message: string; onCta?: () => void }) {
  return (
    <VStack className="flex-1 items-center justify-center gap-4 p-8">
      <Text className="font-sans text-base text-muted-foreground text-center">{message}</Text>
      {onCta && (
        <Button variant="outline" onPress={onCta}>
          <ButtonText>Get started</ButtonText>
        </Button>
      )}
    </VStack>
  );
}
```

## Error state — use Alert destructive

```tsx
import { Alert, AlertText } from '@/components/ui/alert';

function ErrorState({ message }: { message: string }) {
  return (
    <Alert variant="destructive" className="mx-4 my-2">
      <AlertText>{message}</AlertText>
    </Alert>
  );
}
```

## Lists — FlatList for dynamic data, not ScrollView + map

```tsx
// ✅ correct: FlatList for lists of unknown length
import { FlatList } from '@/components/ui/flat-list';

<FlatList
  data={items}
  keyExtractor={item => item.id}
  renderItem={({ item }) => <ItemCard item={item} />}
  contentContainerStyle={{ gap: 12, padding: 16 }}
/>

// ❌ wrong for dynamic lists: causes full re-render
<ScrollView>
  {items.map(item => <ItemCard key={item.id} item={item} />)}
</ScrollView>
```

Use `ScrollView + map` only for short, static lists (< 10 items) like settings screens.

## Animations — right tool for the job

| Use case | Library |
|---|---|
| Gesture-driven (swipe, drag) | `react-native-reanimated` |
| Screen/tab transitions | `react-native-reanimated` |
| Entrance/exit fade/slide | `@legendapp/motion` `<Motion.View>` |
| Hero/splash animations | `react-native-reanimated` useSharedValue |
| Simple opacity toggle | `@legendapp/motion` |

```tsx
// Entrance animation with @legendapp/motion
import { Motion } from '@legendapp/motion';

<Motion.View
  initial={{ opacity: 0, y: 20 }}
  animate={{ opacity: 1, y: 0 }}
  transition={{ type: 'spring', damping: 20 }}
>
  <Card>...</Card>
</Motion.View>

// Programmatic animation with Reanimated
import Animated, { useSharedValue, useAnimatedStyle, withTiming } from 'react-native-reanimated';

const opacity = useSharedValue(0);
const style = useAnimatedStyle(() => ({ opacity: opacity.value }));
opacity.value = withTiming(1, { duration: 400 });

<Animated.View style={style}>...</Animated.View>
```

## Navigation — expo-router only

```tsx
import { useRouter, Link } from 'expo-router';

// Programmatic
const router = useRouter();
router.push('/login');
router.replace('/(tabs)');

// Declarative
<Link href="/signup" asChild>
  <Button><ButtonText>Sign up</ButtonText></Button>
</Link>
```

Never use `@react-navigation/native` directly — expo-router wraps it.

## Icons — lucide-react-native only

```tsx
import { Home, Compass, Settings, ArrowRight } from 'lucide-react-native';

// Always pass color via NativeWind (not style prop)
<Home className="text-primary" size={24} />
```

Never use FontAwesome or other icon packs for new code.
