{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "autoIncrement": false
      },
      "ios": {
        "autoIncrement": false
      },
      "channel": "development"
    },
    "staging": {
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleRelease",
        "autoIncrement": false
      },
      "ios": {
        "simulator": true,
        "autoIncrement": false
      },
      "channel": "staging"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "autoIncrement": false
      },
      "ios": {
        "autoIncrement": false
      },
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": false
      },
      "ios": {
        "autoIncrement": false
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
