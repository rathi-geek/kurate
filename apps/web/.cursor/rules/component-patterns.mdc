## Dropdown Actions Menu

For per-item action menus (edit, delete, share):

```tsx
import {
  DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger,
} from "@/components/ui/dropdown-menu";

<DropdownMenu>
  <DropdownMenuTrigger asChild>
    <Button variant="ghost" size="icon" aria-label={t("actions_label")}>
      <DotsIcon />
    </Button>
  </DropdownMenuTrigger>
  <DropdownMenuContent align="end">
    <DropdownMenuItem onClick={handleEdit}>{t("edit")}</DropdownMenuItem>
    <DropdownMenuItem onClick={handleShare}>{t("share")}</DropdownMenuItem>
    <DropdownMenuItem variant="destructive" onClick={handleDelete}>
      {t("delete")}
    </DropdownMenuItem>
  </DropdownMenuContent>
</DropdownMenu>
```

