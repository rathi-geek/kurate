## Framer Motion

### Always handle reduced motion

```tsx
import { motion, useReducedMotion } from "framer-motion";

const prefersReducedMotion = useReducedMotion();
```

Set `initial={prefersReducedMotion ? false : "hidden"}` and `animate={prefersReducedMotion ? undefined : "visible"}` on every `<motion.*>` element.

### Use the `mp()` helper for staggered animations

Avoids repeating `initial/animate/variants` on each element:

```tsx
import { type Variants, motion, useReducedMotion } from "framer-motion";
import { fadeUp } from "@/app/_libs/utils/motion";

const prefersReducedMotion = useReducedMotion();

const mp = (custom: number) => ({
  custom,
  initial: prefersReducedMotion ? false : ("hidden" as const),
  animate: prefersReducedMotion ? undefined : ("visible" as const),
  variants: fadeUp as Variants,
});

<motion.div {...mp(0)}>first</motion.div>
<motion.div {...mp(1)}>second — staggered by 70ms</motion.div>
<motion.div {...mp(2)}>third</motion.div>
```

### Stagger for lists

```tsx
const cardVariants: Variants = {
  hidden: { opacity: 0, y: 16 },
  visible: (i: number) => ({
    opacity: 1, y: 0,
    transition: { delay: i * 0.05, type: "spring", stiffness: 300, damping: 28 },
  }),
};

{items.map((item, i) => (
  <motion.div
    key={item.id}
    variants={cardVariants}
    initial={prefersReducedMotion ? false : "hidden"}
    animate={prefersReducedMotion ? undefined : "visible"}
    custom={i}
  >
    ...
  </motion.div>
))}
```

### Slide-in panels

```tsx
<AnimatePresence>
  {open && (
    <>
      <motion.div
        key="backdrop"
        className="fixed inset-0 z-40 bg-ink/20"
        initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
        onClick={onClose}
      />
      <motion.div
        key="panel"
        className="fixed inset-y-0 right-0 z-50 w-full max-w-[720px] bg-background"
        initial={{ x: "100%" }} animate={{ x: 0 }} exit={{ x: "100%" }}
        transition={springGentle}
      >
        {/* panel content */}
      </motion.div>
    </>
  )}
</AnimatePresence>
```

Import `springGentle` from `@/lib/motion-variants`. Never define spring configs inline.

