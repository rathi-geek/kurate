## Routes & Translations

```tsx
// Routes — always use constants, never hardcode strings
import { ROUTES } from "@/app/_libs/constants/routes";
router.replace(ROUTES.APP.CHAT);
<Link href={ROUTES.AUTH.LOGIN}>

// Translations — always; never hardcode English
const t = useTranslations("feature.section");      // client component
const t = await getTranslations("feature.section"); // server component
// Add keys to both messages/en-US.json and messages/en-GB.json
```

