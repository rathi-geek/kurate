# ==============================================================================
# KURATE — ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your actual values
# For development, you can use the provided defaults where applicable

# ==============================================================================
# SERVER ENVIRONMENT
# ==============================================================================

# Application Environment
NODE_ENV=development
ANALYZE=false

# ==============================================================================
# CLIENT ENVIRONMENT (Public - exposed to browser)
# ==============================================================================

# App Configuration
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_TITLE="Kurate"
NEXT_PUBLIC_APP_NAME="Kurate"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION="Chat-based content discovery and curation"
NEXT_PUBLIC_APP_CATEGORY="app"
NEXT_PUBLIC_APP_KEYWORDS="kurate,content,curation,discovery"

# ==============================================================================
# ANALYTICS & MONITORING (Optional for development)
# ==============================================================================

# Google Tag Manager (Optional)
# Get your GTM container ID from https://tagmanager.google.com/
NEXT_PUBLIC_GTM_KEY=GTM-XXXXXXX

# PostHog Analytics (Optional for development)
# Sign up at https://posthog.com/ for free analytics
# Personal API Key (for server-side events)
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Environment ID (found in PostHog project settings)
POSTHOG_ENV_ID=env_xxxxxxxx
# Public key (for client-side events)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PostHog host (EU: https://eu.i.posthog.com, US: https://us.i.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Ingest path (proxied to avoid ad blockers)
NEXT_PUBLIC_POSTHOG_INGEST=/ingest
# Environment for PostHog
NEXT_PUBLIC_POSTHOG_ENVIRONMENT=development

# Sentry Error Tracking (Optional for development)
# Get auth token from https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================

# Supabase Project URL (found in Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (found in Supabase dashboard → Settings → API)
# This is the "anon" key, not the service_role key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjQwOTk5MjAwLCJleHAiOjE5NTY1NzUyMDB9.your-anon-key-here

# Supabase Service Role Key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Auth bypass for local development only (NODE_ENV=development). When true,
# unauthenticated users can access protected routes without redirect to login.
# Set to "true" to skip auth redirects during development.
# BYPASS_AUTH=true

# ==============================================================================
# CHROME EXTENSION
# ==============================================================================

# Chrome Extension ID from the Chrome Web Store (server-side only, never NEXT_PUBLIC_).
# Used by /api/extension/session to reject requests from other extensions.
# Leave empty in development — dev builds accept any chrome-extension:// origin.
EXTENSION_ID=

# ==============================================================================
# EMAIL (Resend)
# ==============================================================================

# Resend API Key (found in Resend dashboard → API Keys)
# Required for sending group invite emails
RESEND_API_KEY=re_xxxxxxxxx

# ==============================================================================
# AI / LLM CONFIGURATION
# ==============================================================================

# AI Provider: anthropic | openai
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# DEVELOPMENT NOTES
# ==============================================================================
#
# QUICK START (Minimal setup):
# 1. Copy this file to .env
# 2. Keep all defaults (no analytics)
# 3. Run: pnpm dev
#
# FULL SETUP (All features):
# 1. Copy this file to .env
# 2. Sign up for PostHog (free) and fill in POSTHOG_* variables
# 3. Sign up for Sentry (free) and fill in SENTRY_AUTH_TOKEN
# 4. Get GTM container ID and fill in NEXT_PUBLIC_GTM_KEY
# 5. Run: pnpm dev
#
